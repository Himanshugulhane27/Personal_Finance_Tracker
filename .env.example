# ─── Server ───────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── PostgreSQL ───────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=finance_tracker
DB_USER=postgres
DB_PASSWORD=your_password_here

# ─── JWT ──────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_to_a_random_64_char_string
JWT_REFRESH_SECRET=change_me_to_another_random_64_char_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Bcrypt ──────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12
